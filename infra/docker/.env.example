# ============================================================
# Prize Draw Platform - Docker Compose Environment Variables
# Copy this file to .env and fill in real values before running.
#
# For per-environment configs, use files in env/ directory:
#   docker compose --env-file infra/docker/env/.env.dev up
#   docker compose --env-file infra/docker/env/.env.staging up
# ============================================================

# ----- Application -----
APP_ENV=dev
LOG_LEVEL=DEBUG
RATE_LIMIT_ENABLED=false

# ----- PostgreSQL -----
POSTGRES_DB=prizedraw
POSTGRES_USER=prizedraw
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5432

# ----- Redis -----
REDIS_PASSWORD=change-me-in-production
REDIS_PORT=6379
REDIS_DATABASE=0

# ----- MinIO (S3-compatible) -----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-in-production
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
STORAGE_BUCKET=prizedraw
STORAGE_REGION=us-east-1

# ----- JWT -----
# Use a 256-bit random hex string in production: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-256-bit-secret
JWT_ISSUER=prizedraw
JWT_AUDIENCE=prizedraw-api
JWT_ACCESS_EXPIRY_SECONDS=900
JWT_REFRESH_EXPIRY_DAYS=30

# ----- Backend Service Ports -----
CORE_API_PORT=9092
DRAW_SERVICE_PORT=9093
REALTIME_GATEWAY_PORT=9094
NOTIFICATION_WORKER_METRICS_PORT=9095

# ----- CORS -----
CORS_ALLOWED_HOSTS=localhost:3000,localhost:3001,localhost:3002,localhost:3003

# ----- Frontend Ports -----
WEB_PORT=3000
ADMIN_PORT=3001
CS_PORT=3002

# ----- Frontend API URLs -----
NEXT_PUBLIC_API_URL=http://localhost:9092
NEXT_PUBLIC_WS_URL=ws://localhost:9094
NEXT_PUBLIC_API_BASE_URL=http://localhost:9092

# ----- Firebase Admin SDK -----
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_JSON_PATH=/run/secrets/firebase-service-account.json

# ----- Payment Gateway -----
# Fill with your payment provider credentials (Phase 2)
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_WEBHOOK_SECRET=

# ----- LINE Messaging API -----
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ----- Observability -----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=prize-draw-platform
